# API 密钥
.env
.grindraft/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Node
node_modules/

# 系统
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# 飞书 lark-* skills（安装时自动下载，不提交）
.agents/skills/lark-*
.trae/
.trae/skills/lark-*

# 非 WeChatPost 的遗留文件
/skills/
/skills-lock.json
/.trae/
